# ── Database ──────────────────────────────────────────────────────────────────
# Railway: copy from your Railway Postgres service → Connect tab → connection string
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Get from: stripe listen output (local dev)
# or Stripe Dashboard → Developers → Webhooks → select endpoint → Signing secret (prod)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://yourapp.railway.app
ADMIN_PASSWORD=changeme

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Google (Docs / Drive) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
GOOGLE_DRIVE_FOLDER_ID=...
