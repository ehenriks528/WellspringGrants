# ─────────────────────────────────────────────────────────────────────────────
# .env.local — Local development environment
#
# HOW TO USE:
#   1. Copy this file:  cp .env.local.example .env.local
#   2. Fill in any values marked REPLACE_ME
#   3. Run:  npm run dev
#
# This file is safe to commit. .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────

# Local server URL — do not change this
APP_URL=http://localhost:3000

# Local port — do not change this
PORT=3000

# Admin dashboard password for local use — change if you want
ADMIN_PASSWORD=localadmin


# ── Database ──────────────────────────────────────────────────────────────────

# This connects to your Railway Postgres database.
# Found in: Railway dashboard → your Postgres service → Connect tab → connection string
# NOTE: This is the live Railway database. If you want a fully isolated local
# database instead, see LOCAL_DB_SETUP.md for instructions to create
# wellspring_local on your machine.
DATABASE_URL=postgresql://postgres:RQSjacWVcYAfSvRlEvLDJHdKiPPEkarW@nozomi.proxy.rlwy.net:37089/railway


# ── Anthropic ─────────────────────────────────────────────────────────────────

# Your real Anthropic API key — safe to use locally, charges your account per call
# Found in: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=REPLACE_ME


# ── Stripe ────────────────────────────────────────────────────────────────────

# Use your TEST MODE key (starts with sk_test_) — never use the live key locally
# Found in: Stripe Dashboard → Developers → API keys → Secret key (Test mode)
STRIPE_SECRET_KEY=REPLACE_ME

# Webhook signing secret for local testing via Stripe CLI
# This value is printed in your terminal when you run:  stripe listen --forward-to localhost:3000/webhook
# It changes every time you restart stripe listen — update this when it does
# See STRIPE_LOCAL_SETUP.md for full instructions
STRIPE_WEBHOOK_SECRET=REPLACE_ME


# ── Resend (email) ────────────────────────────────────────────────────────────

# Your real Resend API key — safe to use locally, emails will actually send
# Found in: https://resend.com/api-keys
RESEND_API_KEY=REPLACE_ME


# ── Google (Docs / Drive) ─────────────────────────────────────────────────────

# These are shared with production — using the same credentials locally is fine.
# Documents created locally will appear in the same Google Drive folder.
# Found in: Google Cloud Console → your OAuth 2.0 client → credentials

GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME

# Long-lived refresh token. Generate once with:  node get-google-token.js
GOOGLE_REFRESH_TOKEN=REPLACE_ME

# The Google Drive folder ID where grant docs are saved
# Found in the Drive folder URL: drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_FOLDER_ID=REPLACE_ME
